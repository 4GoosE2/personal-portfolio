---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  /** "sidebar" (sticky right column, desktop) or "strip" (horizontal, mobile). */
  variant: "sidebar" | "strip";
}

const { project, variant } = Astro.props;
import { originPath } from "../lib/origin";

const { category, subcategory, tags, date, metrics, note, track, source, context } = project.data;
const origin = [track, source, context].filter(Boolean).join(" · ");
const originHref = originPath(project);

/** YAML folds blank lines to a single "\n", so split rather than pre-wrap. */
const noteParagraphs = (note ?? "")
  .split(/\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<aside class={`meta-panel meta-${variant}`} aria-label="Project metadata">
  {noteParagraphs.length > 0 && (
    <div class="meta-item meta-note">
      <span class="mono-label">About this project</span>
      {noteParagraphs.map((paragraph) => (
        <p class="note-text">{paragraph}</p>
      ))}
    </div>
  )}

  <div class="meta-item">
    <span class="mono-label">Category</span>
    <span class="mono">{category}</span>
  </div>

  {subcategory && (
    <div class="meta-item">
      <span class="mono-label">Subcategory</span>
      <span class="mono">{subcategory}</span>
    </div>
  )}

  {tags.length > 0 && (
    <div class="meta-item">
      <span class="mono-label">Tags</span>
      <ul class="tag-list" role="list">
        {tags.map((tag) => (
          <li class="mono tag">{tag}</li>
        ))}
      </ul>
    </div>
  )}

  {metrics.length > 0 && (
    <div class="meta-item">
      <span class="mono-label">Key metrics</span>
      <dl class="metric-list">
        {metrics.map((metric, i) => (
          <div class="metric">
            <dt class="mono metric-label">{metric.label}</dt>
            <dd class={`mono ${i === 0 ? "standout" : ""}`}>{metric.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  )}

  {origin && (
    <div class="meta-item">
      <span class="mono-label">Origin</span>
      {originHref ? (
        <a href={originHref} class="mono origin-link">{origin}</a>
      ) : (
        <span class="mono">{origin}</span>
      )}
    </div>
  )}

  <div class="meta-item">
    <span class="mono-label">Date</span>
    <span class="mono">{date}</span>
  </div>
</aside>

<style>
  .meta-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  /* Longer-form note: body type, and it gets a rule beneath to separate it
     from the scannable metadata that follows. */
  .note-text {
    font-size: 0.92rem;
    line-height: 1.55;
    max-width: 44ch;
  }

  .note-text + .note-text {
    margin-top: 0.7em;
  }

  .meta-note {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--hairline);
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
  }

  .tag {
    color: var(--signal);
    font-size: 0.78rem;
  }

  .origin-link {
    color: var(--ink);
    text-decoration-color: var(--rule);
  }

  .origin-link:hover {
    color: var(--signal);
  }

  .metric-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 0;
  }

  .metric {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .metric-label {
    color: var(--fog);
    font-size: 0.78rem;
  }

  .metric dd {
    margin: 0;
  }

  .metric dd.standout {
    color: var(--alert);
    font-weight: 500;
  }

  /* Horizontal strip variant (below the title on narrow viewports) */
  .meta-strip {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
    padding-block: 1.1rem;
    border-block: 1px solid var(--hairline);
  }

  .meta-strip .metric {
    gap: 0.6rem;
    justify-content: flex-start;
  }

  /* The note is prose, so it spans the full strip rather than sitting in
     the metadata row. */
  .meta-strip .meta-note {
    flex-basis: 100%;
    padding-bottom: 0;
    border-bottom: 0;
  }
</style>
