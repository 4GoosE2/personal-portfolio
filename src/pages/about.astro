---
import BaseLayout from "../layouts/BaseLayout.astro";

const highlights = [
  {
    title: "Tobii Power BI Report",
    description: "Designed a full report from scratch during a 20-week internship",
  },
  {
    title: "BI Program Graduate",
    description: "Nackademin, 12+ courses completed",
  },
  {
    title: "Snowflake Certified",
    description: "Cloud data platform fundamentals",
  },
  {
    title: "Bachelor of Honours, International Business Management",
    description: "Coventry University",
  },
  {
    title: "Dissertation: Cross-Border Post-Merger Integration",
    description:
      "First Class (70), using Simons' Four Levers of Control framework",
  },
];
---

<BaseLayout title="About — Mårten Wikman">
  <article class="about">
    <header class="reveal">
      <h1>About</h1>
      <p class="tagline mono-label">Hybrid finance and data profile</p>
    </header>

    <section class="reveal">
      <div class="prose">
        <p>
          I'm a Business Intelligence Analyst with a passion for transforming
          complex data into clear, actionable insights. Having completed my
          BSc (Hons) in International Business Management at FEI in
          collaboration with Coventry University, I combine academic excellence
          with hands-on technical expertise.
        </p>
        <p>
          My journey in business intelligence began at Nackademin, where I
          completed a comprehensive BI program covering everything from data
          visualization and SQL to Python and machine learning. During my
          20-week internship at Tobii, I designed and developed a complete
          Power BI report from scratch, demonstrating my ability to deliver
          real-world solutions.
        </p>
        <p>
          I thrive on turning data challenges into opportunities, whether it's
          building interactive dashboards, optimizing database queries, or
          uncovering hidden patterns that drive business decisions. With a
          strong foundation in business strategy, I bring both technical
          prowess and business acumen to every project.
        </p>
        <p>
          I'm 24 and based just outside Stockholm. When I'm not working with
          data, you'll usually find me somewhere less digital, out on the water
          fishing or diving, under the hood of a boat or a car, or out hunting.
        </p>
      </div>
    </section>

    <section class="reveal" aria-labelledby="highlights-heading">
      <h2 id="highlights-heading" class="mono-label section-label">Certifications &amp; Highlights</h2>
      <ul class="highlight-list" role="list">
        {highlights.map((item) => (
          <li>
            <span class="highlight-title">{item.title}</span>
            <span class="highlight-desc">{item.description}</span>
          </li>
        ))}
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 46rem;
  }

  .tagline {
    margin-top: 0.9rem;
  }

  .about section {
    padding-top: 2rem;
    border-top: 1px solid var(--hairline);
  }

  .section-label {
    margin-bottom: 1.5rem;
  }

  .highlight-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .highlight-list li {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-block: 1.1rem;
    border-bottom: 1px solid var(--hairline);
  }

  .highlight-list li:last-child {
    border-bottom: 0;
  }

  .highlight-title {
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .highlight-desc {
    color: var(--fog);
    font-size: 0.95rem;
  }
</style>
