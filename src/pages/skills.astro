---
import BaseLayout from "../layouts/BaseLayout.astro";

const slugify = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

const groups = [
  {
    title: "Technical",
    skills: [
      { name: "Python", level: 40 },
      { name: "Data Visualization", level: 80 },
      { name: "Power BI", level: 70 },
      { name: "Analytics", level: 80 },
      { name: "SQL", level: 75 },
      { name: "Machine Learning", level: 25 },
    ],
  },
  {
    title: "Business & Management",
    skills: [
      { name: "Accounting and Finance", level: 55 },
      { name: "Business and Sustainability", level: 65 },
      { name: "International Marketing", level: 72 },
      {
        name: "Organisational Behaviour and Leadership in an International Context",
        level: 70,
      },
      { name: "Strategic Management", level: 60 },
    ],
  },
];
---

<BaseLayout title="Skills — Mårten Wikman">
  <article class="skills">
    <header class="reveal">
      <h1>Skills</h1>
      <p class="tagline mono-label">Technical Proficiency</p>
    </header>

    {groups.map((group) => (
      <section class="group reveal" aria-labelledby={`group-${slugify(group.title)}`}>
        <h2 id={`group-${slugify(group.title)}`} class="mono-label group-label">{group.title}</h2>
        <ul class="skill-list" role="list">
          {group.skills.map((skill) => (
            <li class="skill">
              <div class="skill-head">
                <span class="skill-name">{skill.name}</span>
                <span class="mono skill-value">{skill.level}%</span>
              </div>
              <div
                class="bar"
                role="meter"
                aria-valuenow={skill.level}
                aria-valuemin="0"
                aria-valuemax="100"
                aria-label={`${skill.name} proficiency`}
              >
                <div class="bar-fill" style={`width: ${skill.level}%`}></div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </article>
</BaseLayout>

<style>
  .skills {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .tagline {
    margin-top: 0.9rem;
  }

  .group {
    padding-top: 2rem;
    border-top: 1px solid var(--hairline);
  }

  .group-label {
    margin-bottom: 1.75rem;
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.9rem;
  }

  .skill {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .skill-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .skill-name {
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .skill-value {
    color: var(--fog);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .bar {
    height: 3px;
    background: var(--rule);
  }

  .bar-fill {
    height: 100%;
    background: var(--signal);
  }
</style>
