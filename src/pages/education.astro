---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Course {
  name: string;
  grade?: string;
  /** Highlights the one grade being called out (rendered in --alert). */
  standout?: boolean;
}

interface Entry {
  id: string;
  title: string;
  org: string;
  body: string;
  tags: string[];
  courses: Course[];
}

const entries: Entry[] = [
  {
    id: "coventry",
    title: "BSc (Hons) International Business Management (Top-up)",
    org: "FEI in collaboration with Coventry University",
    body: "Advanced business management studies with a focus on international perspectives, developing strategic thinking and global business acumen.",
    tags: [
      "Accounting and Finance",
      "Business and Sustainability",
      "Business Data Analysis",
      "International Marketing",
      "Organisation Behaviour and Leadership",
      "Strategic Management",
      "Dissertation",
    ],
    courses: [
      { name: "Accounting and Finance" },
      { name: "Business and Sustainability" },
      { name: "Business Data Analysis" },
      { name: "Dissertation", grade: "First Class (70)", standout: true },
      { name: "International Marketing" },
      { name: "Organisational Behaviour and Leadership in an International Context" },
      { name: "Strategic Management" },
    ],
  },
  {
    id: "nackademin",
    title: "Business Intelligence Program",
    org: "Nackademin, Stockholm",
    body: "Comprehensive BI program including a 20-week internship at Tobii. Gained hands-on experience in data analytics, visualization, and business intelligence tools.",
    tags: [
      "Power BI",
      "Data Visualization",
      "SQL & Database Design",
      "Python Programming",
      "Machine Learning",
      "Advanced Analytics",
      "BI Strategy",
      "Data Warehousing",
    ],
    courses: [
      { name: "Statistik och dataanalys", grade: "VG" },
      { name: "Systemförståelse och verksamhetsprocesser inom BI", grade: "VG" },
      { name: "Databasdesign och modellering", grade: "G" },
      { name: "SQL", grade: "VG" },
      { name: "Datafångst, migrering och förädling", grade: "G" },
      { name: "Business Intelligence relaterade programspråk", grade: "G" },
      { name: "Avancerad analys", grade: "G" },
      { name: "Statistisk programmering och maskininlärning", grade: "G" },
      { name: "Datavisualisering", grade: "G" },
      { name: "Examensarbete", grade: "VG" },
      { name: "LIA", grade: "VG" },
      { name: "Affärsmannaskap", grade: "VG" },
      { name: "Business Intelligence och dess affärsmöjligheter", grade: "VG" },
      { name: "Strömmande data och molnlösningar", grade: "VG" },
    ],
  },
];
---

<BaseLayout title="Education — Mårten Wikman">
  <article class="education">
    <header class="reveal">
      <h1>Education</h1>
      <p class="tagline mono-label">Academic Background</p>
    </header>

    <ol class="timeline reveal" role="list">
      {entries.map((entry) => (
        <li class="entry">
          <button
            type="button"
            class="dot"
            data-toggle={entry.id}
            aria-expanded="false"
            aria-controls={`courses-${entry.id}`}
            aria-label={`Show courses for ${entry.title}`}
          ></button>
          <div class="entry-body">
            <h2 class="entry-title">
              <button
                type="button"
                class="title-toggle"
                data-toggle={entry.id}
                aria-expanded="false"
                aria-controls={`courses-${entry.id}`}
              >
                {entry.title}
                <span class="mono toggle-hint" aria-hidden="true">Courses</span>
              </button>
            </h2>
            <span class="mono entry-org">{entry.org}</span>
            <p>{entry.body}</p>
            <ul class="tag-list" role="list">
              {entry.tags.map((tag) => (
                <li class="pill mono">{tag}</li>
              ))}
            </ul>

            <div class="courses" id={`courses-${entry.id}`} data-panel={entry.id} hidden>
              <div class="courses-inner">
                <ul class="course-list" role="list">
                  {entry.courses.map((course) => (
                    <li class="course">
                      <span class="course-name">{course.name}</span>
                      {course.grade && (
                        <span class={`mono course-grade ${course.standout ? "standout" : ""}`}>
                          {course.grade}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </article>
</BaseLayout>

<script>
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll<HTMLElement>("[data-panel]").forEach((panel) => {
    const id = panel.dataset.panel;
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>(`[data-toggle="${id}"]`)
    );

    const setExpanded = (open: boolean) => {
      triggers.forEach((t) => t.setAttribute("aria-expanded", String(open)));
      panel.classList.toggle("is-open", open);
    };

    const open = () => {
      panel.hidden = false;
      setExpanded(true);
      if (prefersReduced) {
        panel.style.height = "auto";
        return;
      }
      const target = panel.scrollHeight;
      panel.style.height = "0px";
      // Force layout so the browser registers the starting height.
      void panel.offsetHeight;
      panel.style.height = `${target}px`;
      panel.addEventListener(
        "transitionend",
        () => {
          if (panel.classList.contains("is-open")) panel.style.height = "auto";
        },
        { once: true }
      );
    };

    const close = () => {
      setExpanded(false);
      if (prefersReduced) {
        panel.hidden = true;
        return;
      }
      panel.style.height = `${panel.scrollHeight}px`;
      void panel.offsetHeight;
      panel.style.height = "0px";
      panel.addEventListener(
        "transitionend",
        () => {
          if (!panel.classList.contains("is-open")) panel.hidden = true;
        },
        { once: true }
      );
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        if (panel.classList.contains("is-open")) close();
        else open();
      });
    });
  });
</script>

<style>
  .education {
    max-width: 46rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .tagline {
    margin-top: 0.9rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
  }

  /* Thin vertical rule connecting the timeline */
  .timeline::before {
    content: "";
    position: absolute;
    left: 0.3125rem;
    top: 2.5rem;
    bottom: 1.5rem;
    width: 1px;
    background: var(--rule);
  }

  .entry {
    position: relative;
    padding-left: 2.25rem;
    padding-block: 1rem 2.5rem;
  }

  .entry:last-child {
    padding-bottom: 0.5rem;
  }

  .dot {
    position: absolute;
    left: 0;
    top: 1.55rem;
    width: 0.6875rem;
    height: 0.6875rem;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: var(--signal);
    cursor: pointer;
    transition: box-shadow 150ms ease;
  }

  .dot:hover,
  .dot[aria-expanded="true"] {
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--signal) 22%, transparent);
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .entry-title {
    font-size: 1.2rem;
  }

  .title-toggle {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    text-align: left;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .title-toggle:hover {
    color: var(--signal);
  }

  .toggle-hint {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fog);
    white-space: nowrap;
  }

  .toggle-hint::after {
    content: " +";
  }

  .title-toggle[aria-expanded="true"] .toggle-hint::after {
    content: " −";
  }

  .entry-body p {
    max-width: var(--measure);
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin-top: 0.4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    font-size: 0.72rem;
    color: var(--fog);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }

  /* Accordion panel */
  .courses {
    height: 0;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: no-preference) {
    .courses {
      transition: height 320ms ease;
    }
  }

  .courses-inner {
    padding-top: 1.4rem;
  }

  .course-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .course {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.6rem;
    border-bottom: 1px solid var(--hairline);
  }

  .course:first-child {
    border-top: 1px solid var(--hairline);
  }

  .course-name {
    font-size: 0.95rem;
  }

  .course-grade {
    font-size: 0.78rem;
    color: var(--fog);
    flex-shrink: 0;
  }

  .course-grade.standout {
    color: var(--alert);
    font-weight: 500;
  }
</style>
